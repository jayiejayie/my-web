{
  "version": "2.0",
  "envId": "{{env.ENV_ID}}",
  "framework": {
    "name": "my-web",
    "plugins": {
      "web": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "buildCommand": "npm run docs:build",
          "outputPath": "docs/.vitepress/dist",
          "cloudPath": "/",
          "ignore": [".git", "node_modules", "docs/.vitepress/cache"]
        }
      }
    }
  }
}
